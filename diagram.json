    { "type": "wokwi-resistor", "id": "r1", "top": -150, "left": 200, "rotate": 90, "attrs": { "resistance": "4700" } },
    { "type": "wokwi-resistor", "id": "r2", "top": -150, "left": 220, "rotate": 90, "attrs": { "resistance": "4700" } },
