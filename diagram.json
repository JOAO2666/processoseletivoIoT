    [ "esp:22", "imu1:SCL", "blue", [] ],
    [ "esp:3V3", "r1:1", "red", [] ],
    [ "r1:2", "imu1:SDA", "green", [] ],
    [ "esp:3V3", "r2:1", "red", [] ],
    [ "r2:2", "imu1:SCL", "blue", [] ],
    [ "esp:3V3", "btn1:1.l", "red", [] ],
    [ "esp:4", "btn1:2.l", "green", [] ]
  ]
